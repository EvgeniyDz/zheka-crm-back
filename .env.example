NODE_ENV=development
PORT=4000
API_PREFIX=api
APP_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:1488,http://localhost:3000

# Production and staging values are managed through GitHub Secrets.
# Local .env files are for development only and must never be committed.

SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

CHECKBOX_API_URL=https://api.checkbox.in.ua/api/v1
CHECKBOX_CLIENT_NAME=zheka-crm-back
CHECKBOX_CLIENT_VERSION=0.1.0

NOVA_POSHTA_API_URL=https://api.novaposhta.ua/v2.0/json/
NOVA_POSHTA_API_KEY=your_nova_poshta_api_key

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

